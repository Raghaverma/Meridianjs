{
  "name": "meridianjs",
  "version": "0.3.3",
  "description": "Meridian - A TypeScript-first SDK that enforces a single stable contract across all third-party API providers",
  "main": "dist/public.js",
  "types": "dist/public.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    },
    "./contract": {
      "types": "./dist/testing/contract.d.ts",
      "import": "./dist/testing/contract.js"
    },
    "./upi": {
      "types": "./dist/upi/index.d.ts",
      "import": "./dist/upi/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "contract": [
        "./dist/testing/contract.d.ts"
      ],
      "upi": [
        "./dist/upi/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "proto",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "prebuild": "npm run sync-version",
    "build": "tsc",
    "pretest": "npm run sync-version",
    "pretypecheck": "npm run sync-version",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:ci": "biome ci .",
    "format": "biome format --write .",
    "providers:list": "node scripts/list-providers.mjs --pretty",
    "prepublishOnly": "npm run build",
    "proxy": "node dist/proxy/cli.js",
    "proxy:build": "npm run build && npm run proxy",
    "example:swap": "vite-node examples/provider-swap/index.ts",
    "example:reliability-lab": "npx vite-node examples/reliability-lab/index.ts",
    "test:contracts": "node scripts/test-contracts.mjs",
    "test:contracts:all": "node scripts/test-contracts.mjs",
    "benchmark": "MERIDIAN_BENCH_SUITE=1 npx vite-node benchmarks/index.ts",
    "benchmark:reliability": "npx vite-node benchmarks/reliability.ts",
    "benchmark:overhead": "npx vite-node benchmarks/pipeline-overhead.ts",
    "demo:failover": "npx vite-node demos/failover.ts",
    "demo:circuit-breaker": "npx vite-node demos/circuit-breaker.ts",
    "demo:schema-drift": "npx vite-node demos/schema-drift.ts",
    "demo:service-routing": "npx vite-node demos/service-routing.ts",
    "pkg:check": "npx publint && npx @arethetypeswrong/cli . --pack --ignore-rules cjs-resolves-to-esm"
  },
  "bin": {
    "boundary-proxy": "dist/proxy/cli.js",
    "meridian": "dist/cli/main.js"
  },
  "keywords": [
    "api",
    "sdk",
    "normalization",
    "circuit-breaker",
    "rate-limiting",
    "retry"
  ],
  "license": "MIT",
  "homepage": "https://meridianjs.raghav-verma.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raghaverma/meridianjs.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.7.0",
    "@opentelemetry/api": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@grpc/grpc-js": {
      "optional": true
    },
    "@grpc/proto-loader": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@opentelemetry/api": "^1.9.1",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
