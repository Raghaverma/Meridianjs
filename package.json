{
  "name": "meridianjs",
  "version": "0.2.5",
  "description": "Meridian - A TypeScript-first SDK that enforces a single stable contract across all third-party API providers",
  "main": "dist/public.js",
  "types": "dist/public.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    },
    "./contract": {
      "types": "./dist/testing/contract.d.ts",
      "import": "./dist/testing/contract.js"
    },
    "./upi": {
      "types": "./dist/upi/index.d.ts",
      "import": "./dist/upi/index.js"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepublishOnly": "npm run build",
    "proxy": "node dist/proxy/cli.js",
    "proxy:build": "npm run build && npm run proxy",
    "example:swap": "vite-node examples/provider-swap/index.ts",
    "test:contracts": "node scripts/test-contracts.mjs",
    "test:contracts:all": "node scripts/test-contracts.mjs",
    "benchmark": "npx tsx benchmarks/pipeline-overhead.ts",
    "pkg:check": "npx publint && npx are-the-types-wrong . --pack"
  },
  "bin": {
    "boundary-proxy": "dist/proxy/cli.js",
    "meridian": "dist/generator/cli.js"
  },
  "keywords": ["api", "sdk", "normalization", "circuit-breaker", "rate-limiting", "retry"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Raghaverma/meridianjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
