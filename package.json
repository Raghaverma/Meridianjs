{
  "name": "meridianjs",
  "version": "0.2.8",
  "description": "Meridian - A TypeScript-first SDK that enforces a single stable contract across all third-party API providers",
  "main": "dist/public.js",
  "types": "dist/public.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    },
    "./contract": {
      "types": "./dist/testing/contract.d.ts",
      "import": "./dist/testing/contract.js"
    },
    "./upi": {
      "types": "./dist/upi/index.d.ts",
      "import": "./dist/upi/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:ci": "biome ci .",
    "format": "biome format --write .",
    "providers:list": "node scripts/list-providers.mjs --pretty",
    "prepublishOnly": "npm run build",
    "proxy": "node dist/proxy/cli.js",
    "proxy:build": "npm run build && npm run proxy",
    "example:swap": "vite-node examples/provider-swap/index.ts",
    "example:reliability-lab": "npx vite-node examples/reliability-lab/index.ts",
    "test:contracts": "node scripts/test-contracts.mjs",
    "test:contracts:all": "node scripts/test-contracts.mjs",
    "benchmark": "MERIDIAN_BENCH_SUITE=1 npx vite-node benchmarks/index.ts",
    "benchmark:reliability": "npx vite-node benchmarks/reliability.ts",
    "benchmark:overhead": "npx vite-node benchmarks/pipeline-overhead.ts",
    "pkg:check": "npx publint && npx @arethetypeswrong/cli . --pack"
  },
  "bin": {
    "boundary-proxy": "dist/proxy/cli.js",
    "meridian": "dist/generator/cli.js"
  },
  "keywords": [
    "api",
    "sdk",
    "normalization",
    "circuit-breaker",
    "rate-limiting",
    "retry"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raghaverma/meridianjs.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
