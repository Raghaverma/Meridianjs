# Keep the build context tiny and never ship local state or secrets.
node_modules
dist
coverage
clients
benchmarks
demos
examples
docs
blog
assets
# Keep scripts out of the image, but the build stage's `prebuild` hook
# (npm run sync-version) needs sync-version.mjs, so let that one file through.
scripts/*
!scripts/sync-version.mjs
**/__snapshots__
**/*.test.ts
**/*.tsbuildinfo
*.log
.git
.github
.claude
.env
.env.*
.DS_Store
*.tgz
.meridian
.omc
.omx
