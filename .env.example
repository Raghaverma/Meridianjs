# Copy to `.env` and fill in. Used by `docker compose up`.
# NEVER commit your real .env — it is gitignored.

# REQUIRED — shared secret every client must present. Generate a strong one:
#   openssl rand -hex 32
MERIDIAN_PROXY_TOKEN=

# Provider credentials — set only the providers you call.
# The proxy injects these upstream; your client code never sees a real secret.
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
