# Copy to `.env` and fill in. Used by `docker compose up`.
# NEVER commit your real .env — it is gitignored.

# REQUIRED — shared secret every client must present. Generate a strong one:
#   openssl rand -hex 32
MERIDIAN_PROXY_TOKEN=

# Provider credentials — set only the providers you call.
# The proxy injects these upstream; your client code never sees a real secret.
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
STRIPE_SECRET_KEY=

# Newly proxy-wired providers (set only what you use):
BILLDESK_CLIENT_ID=
BILLDESK_SECRET_KEY=
CCAVENUE_ACCESS_CODE=
CCAVENUE_WORKING_KEY=
DATADOG_API_KEY=
DATADOG_APP_KEY=
GOOGLE_MAPS_API_KEY=
HUNTER_API_KEY=
# S3 / S3-compatible (R2, MinIO). AWS_REGION defaults to us-east-1.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_SESSION_TOKEN=
SENTRY_AUTH_TOKEN=
